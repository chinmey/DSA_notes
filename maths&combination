        int n = bombs.size();
        int ans = 1;

        for (int i = 0; i < n; i++) {
            vector<bool> exploded(n, false);  // Reset exploded array for each bomb
            int explode = 0;
            dfs(i, exploded, explode, bombs);
            ans = max(ans, explode);
        }

        return ans;
    }
