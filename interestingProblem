Leetcode 2402 - https://leetcode.com/problems/meeting-rooms-iii/description/ (CodeStoryWithMik)

Unique concept here was use of 2 heaps , one for roomsUsed and another for availablerooms, basically maintaining heaps with each other 

class Solution {
public:
    typedef pair<long long, int> P;

    int mostBooked(int n, vector<vector<int>>& meetings) {
        int m = meetings.size();

        sort(begin(meetings), end(meetings));

        vector<int> roomsUsedCount(n, 0); //Each room is used 0 times in the beginning

        priority_queue<P, vector<P>, greater<P>> usedRooms;
        //To store {earliest room empty time, room No.}
        
        priority_queue<int, vector<int>, greater<int>> unusedRooms;
        //To store rooms that are used
        
        for(int room = 0; room < n; room++) {
            unusedRooms.push(room); 
        }

        for(vector<int>& meet : meetings) {
            int start  = meet[0];
            int end    = meet[1];

            //First see, by this time, which rooms can be empty now
            //And move them to unusedRooms
            while(!usedRooms.empty() && usedRooms.top().first <= start) {
                int room = usedRooms.top().second;
                usedRooms.pop();
                unusedRooms.push(room);
            }

            if(!unusedRooms.empty()) {
                int room = unusedRooms.top();
                unusedRooms.pop();
                usedRooms.push({end, room});
                roomsUsedCount[room]++;
            } else { //We don't have any room available now. Pick earliest end room
                int room          = usedRooms.top().second;
                long long endTime = usedRooms.top().first;
                usedRooms.pop();
                usedRooms.push({endTime + (end-start), room});
                roomsUsedCount[room]++;
            }

        }

        int resultRoom = -1;
        int maxUse     = 0;  
        for(int room = 0; room < n; room++) {
            if(roomsUsedCount[room] > maxUse) {
                maxUse = roomsUsedCount[room];
                resultRoom = room;
            }
        }

        return resultRoom;
    }
};

Leetcode 2262 - https://leetcode.com/problems/total-appeal-of-a-string/ (vivek malik)

PS - The appeal of a string is the number of distinct characters found in the string.

For example, the appeal of "abbca" is 3 because it has 3 distinct characters: 'a', 'b', and 'c'.
Given a string s, return the total appeal of all of its substrings.


The naive approach would be to try every substring and count but taht is 0(N2)

The concept used is called contributions, instead of counting unique characters we count number of substring in which a particualr character occurs and sum that. let us 
take a example 

ex for aba
        a       b                   ans is 9 ( 5 + 4)
a       1       0
b       0       1
a       1       0
ab      1       1
ba      1       1
aba     1       1

so the problem now boils down to for a given string how to find number of substrings in which a char example ('a') occurs --> we find total where a does not occur and subtract from total

class Solution {
public:
    long long appealSum(string s) {
        int n = s.size();
        long long totalSub = (long long)n * (n + 1) / 2;
        long long ans = 0;

        for(char c = 'a'; c <= 'z'; c++) {

            long long without = 0;
            int len = 0;

            for(int i = 0; i < n; i++) {

                if(s[i] == c) {
                    without += (long long)len * (len + 1) / 2;
                    len = 0;
                }
                else {
                    len++;
                }
            }

            without += (long long)len * (len + 1) / 2;

            ans += totalSub - without;
        }

        return ans;
    }
};




Leetcode 2167 - https://leetcode.com/problems/minimum-time-to-remove-all-cars-containing-illegal-goods/description/ (vivek malik)

We got to know about multistage dp where we restrict ourself in movement because either the prefix or suffix needs to be selected

class Solution {
public:
    vector<vector<int>> dp;
    int minimumTime(string s) {
        int n = s.size();

        dp.resize(n, vector<int> (3, -1));
        return helper(s, 0, 0);
    }

    int helper(string &s, int idx, int stage) {
        if(idx == s.size()) return 0;

        if(dp[idx][stage] != -1) return dp[idx][stage];

        if(stage == 0) { // Left

            int continueLeft = 1 + helper(s, idx + 1, 0);
            int moveMid = helper(s, idx, 1);

            return dp[idx][stage] = min(continueLeft, moveMid);
        } else if (stage == 1) { // Mid

            int stayMid = (s[idx] == '1' ? 2 : 0) + helper(s, idx + 1, 1);
            int moveRight = helper(s, idx , 2);

            return dp[idx][stage] = min(stayMid, moveRight);

        } else if (stage == 2) { // Right

            return dp[idx][stage] = s.size()-idx;
        }

        return 0;
    }
};

